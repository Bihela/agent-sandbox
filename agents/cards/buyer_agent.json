{
  "agent_name": "LLMBuyerAgent",
  "version": "1.0.0",
  "framework": "agent-sandbox",
  "protocol": "sandbox-v1",
  "description": "An LLM-powered buyer agent that negotiates to purchase goods at the lowest possible price within a strict budget constraint.",
  "role": "buyer",
  "capabilities": [
    "price_negotiation",
    "counter_offering",
    "budget_enforcement",
    "strategy_adaptation"
  ],
  "strategy_options": ["aggressive", "balanced", "conservative", "adaptive", "cooperative", "analytical"],
  "models_supported": ["mistral", "llama3", "qwen2.5", "gemma"],
  "parameters": {
    "max_price": {
      "type": "float",
      "required": true,
      "description": "Maximum budget the buyer will not exceed"
    },
    "temperature": {
      "type": "float",
      "default": 0.7,
      "range": [0.0, 2.0],
      "description": "LLM creativity/randomness control"
    },
    "strategy_name": {
      "type": "string",
      "default": "balanced",
      "description": "Negotiation strategy module to use"
    }
  },
  "input_schema": {
    "type": "state",
    "fields": ["current_price"]
  },
  "output_schema": {
    "type": "action",
    "fields": ["type", "price", "reasoning"]
  },
  "tags": ["negotiation", "buyer", "llm", "ollama"]
}
